# Gnosis Chain read RPC (optional — defaults to https://rpc.gnosischain.com)
VITE_GNOSIS_RPC=https://rpc.gnosischain.com

# WalletConnect Cloud project id — required for the WalletConnect/mobile QR option.
# Get one free at https://cloud.reown.com (formerly WalletConnect Cloud).
# Injected wallets (MetaMask, Rabby, browser extensions) work WITHOUT this.
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID
